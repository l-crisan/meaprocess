						    Driver.cpp 
						    DriverImpl.cpp
						    Factory.cpp
						   ;

LinkFlags  mps-can-drv  : $(MPS_LINKFLAGS) ;

MakeLocate mps-can-drv : $(MPS_BINDIR) ;
