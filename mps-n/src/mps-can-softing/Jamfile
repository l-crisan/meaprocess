						   SoftingCANDriver.cpp
 						   SoftingCANDriverImpl.cpp
						   Factory.cpp
						   ;						  


LinkFlags  mps-can-softing  : $(MPS_LINKFLAGS) canL2.lib ;

LinkFlags  mps-can-softing  : $(MPS_LINKFLAGS) ;

LinkSharedLibraries mps-can-softing : mps-drv-can ;

MakeLocate  mps-can-softing : $(MPS_BINDIR) ;
