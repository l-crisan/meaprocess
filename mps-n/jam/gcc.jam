# NOTE: dylibs on macosx
#
#If possible, you'll build your dynamic library with the appropriate install_name
#
#$ gcc foo.c -dynamiclib -o libfoo.dylib -install_name @executable_path/../Libraries/libfoo.dylib
#$ otool -L libfoo.dylib
#libfoo.dylib:
# @executable_path/../Libraries/libfoo.dylib (compatibility version 0.0.0, current version 0.0.0)
# /usr/lib/libgcc_s.1.dylib (compatibility version 1.0.0, current version 1.0.0)
# /usr/lib/libSystem.B.dylib (compatibility version 1.0.0, current version 111.0.0)
#
#Then you'll link your application as normal, and when you put the library in Contents/Libraries everything will just work�
#
#If building the dynamic library appropriately isn't an option (a closed-source third-party library for example), don't worry. It's the install_name copied to your program that's really important, and that can be fudged. You'll link your application with the -headerpad_max_install_names flag, then edit it with install_name_tool.
#
#$ gcc main.c -L. -lfoo -headerpad_max_install_names
#$ otool -L a.out
#a.out:
# /usr/local/lib/libfoo.dylib (compatibility version 0.0.0, current version 0.0.0)
# /usr/lib/libgcc_s.1.dylib (compatibility version 1.0.0, current version 1.0.0)
# /usr/lib/libSystem.B.dylib (compatibility version 1.0.0, current version 111.0.0)
#$ install_name_tool -change /usr/local/lib/libfoo.dylib @executable_path/../Libraries/libfoo.dylib a.out
#$ otool -L a.out
#a.out:
# @executable_path/../Libraries/libfoo.dylib (compatibility version 0.0.0, current version 0.0.0)
# /usr/lib/libgcc_s.1.dylib (compatibility version 1.0.0, current version 1.0.0)
# /usr/lib/libSystem.B.dylib (compatibility version 1.0.0, current version 111.0.0)
#
#
# NOTE: future platform checks
#
# ConfigureCc WITH_GCC_FLAG_PSEUDO_RELOC : "int main() { return 0; }"
#                                        : "-Wl,--enable-runtime-pseudo-reloc" ;
#
# ConfigureCc WITH_GCC_FLAG_VISIBILITY  : "int main() { return 0; }"
#                                       : "-fvisibility-inlines-hidden -fvisibility=hidden" ;
#
# ConfigureCc WITH_GCC_FLAG_EXPORT : "int main() { return 0; }"
#                                  : "-Wl,-E" ;
#
# ConfigureCc WITH_GCC_FLAG_RPATH : "int main() { return 0; }"
#                                 : "-Wl,-rpath-link jam" ;
#
# ConfigureCc WITH_GCC_FLAG_GROUPLIBS : "int main() { return 0; }"
#                                     : "-Wl,--start-group -Wl,--end-group" ;
#
# ConfigureCc WITH_GCC_FLAG_DYNAMICLIB : "int main() { return 0; }"
#                                      : "-dynamiclib -install_name test" ;
#
# ConfigureCc WITH_GCC_FLAG_SHARED : "int main() { return 0; }"
#                                  : "-shared" ;

##############################################################################
# Configuration rules
##############################################################################

rule TryBuild
{
    local _cc = $(1) ;
    local _src = $(2) ;
    local _cflags = $(3) ;
    local _l = $(4) ;
    local _L = $(5) ;
    local _out = a.out ;
    local _cmd ;

    if $(4)
    {
        _cmd = $(_cc) $(LINKFLAGS) -o $(_out) $(_cflags) -I$(STDHDRS) -L$(5) $(_src) $(4) ;
    }
    else
    {
        _cmd = $(_cc) -c -o $(_out) $(_cflags) -I$(STDHDRS) $(_src) ;
    }

    local _r = [ TryCommand $(_cmd) ] ;

    TryCommand $(RM) $(_out) ;
    return $(_r) ;
}


rule TryBuildCc
{
    local _cflags = $(CCFLAGS) $(2) ;
    return [ TryBuild $(CC) : $(1) : $(_cflags) : $(3) : $(4) : $(5) ] ;
}


rule TryBuildC++
{
    local _cflags = $(C++FLAGS) $(2) ;
    return [ TryBuild $(C++) : $(1) : $(_cflags) : $(3) : $(4) : $(5) ] ;
}


rule Gcc-CheckCc
{
    TOOLSET_ROOT ?= "" ;

    if $(TOOLSET_ROOT) && $(OS:L) = nt
    {
      TOOLSET_ROOT = $(TOOLSET_ROOT:J=" ") ;
      TOOLSET_ROOT = \"$(TOOLSET_ROOT)\" ;
    }

    AS           ?= $(TOOLSET_ROOT)as ;
    CC           ?= $(TOOLSET_ROOT)gcc ;
    RANLIB       ?= $(TOOLSET_ROOT)ranlib ;
    AR           ?= $(TOOLSET_ROOT)ar ru ;
    LINK         ?= $(CC) ;

    Configure AS ;
    Configure AR ;
    Configure CC ;
    Configure LINK ;
    Configure RANLIB ;

    if $(TARGET_OS:L) = macosx
    {
        DLL_LINKFLAGS = -dynamiclib ;
    }
    else if $(TARGET_OS:L) = nt
    {
        DLL_LINKFLAGS = -shared ;
        LINKFLAGS  += "-Wl,--enable-runtime-pseudo-reloc"  ;
        GCC_START_GROUP = "-Wl,--start-group" ;
        GCC_END_GROUP = "-Wl,--end-group" ;
        RPATH_LINKFLAGS = "-Wl,-rpath-link" ;
    }
    else
    {
        # linker flag -E: export global symbols from the executable
        MAIN_LINKFLAGS = "-Wl,-E" ;
        DLL_LINKFLAGS = -shared ;
        GCC_START_GROUP = "-Wl,--start-group" ;
        GCC_END_GROUP = "-Wl,--end-group" ;
        RPATH_LINKFLAGS = "-Wl,-rpath-link" ;
    }

    if $(WITH_GCC_FLAG_VISIBILITY)
    {
        CCFLAGS    += -fvisibility=hidden ;
        LINKFLAGS  += -fvisibility=hidden ;
    }

    # only use -fPIC for non-X86 CPUs
    if $(TARGET_OSPLAT:U) != X86
    {
        CCFLAGS += -fPIC ;
    }

    if $(WITH_DEBUG) && $(WITH_OPTIM)
    {
        CCFLAGS += -DNDEBUG -g ;
    }
    else if $(WITH_DEBUG)
    {
        CCFLAGS += -DDEBUG -g ;
    }
    else
    {
        CCFLAGS += -DNDEBUG ;
    }

    if $(WITH_OPTIM)
    {
        OPTIM ?= -O2 ;
    }
    else
    {
        OPTIM ?= -O0 ;
    }

    WARN ?= -Wall ;

	Configure STDHDRS ;
    Configure CCFLAGS ;
    Configure WARN ;
    Configure OPTIM ;
    Configure LINKFLAGS ;
    Configure DLL_LINKFLAGS ;
    Configure MAIN_LINKFLAGS ;
    Configure RPATH_LINKFLAGS ;
    Configure GCC_START_GROUP ;
    Configure GCC_END_GROUP ;
}


rule Gcc-CheckC++
{
    ConfigureCc ;

    C++ ?= $(TOOLSET_ROOT)g++ ;
    Configure C++ ;

    LINK++ = $(C++) ;
    Configure LINK++ ;

    #if $(WITH_GCC_FLAG_VISIBILITY)
    #{
    #    C++FLAGS += -fvisibility-inlines-hidden ;
    #    LINKFLAGS += -fvisibility-inlines-hidden ;
    #}

    # only use -fPIC for non-X86 CPUs
    if $(TARGET_OSPLAT:U) != X86
    {
        C++FLAGS += -fPIC ;
    }

    if $(WITH_DEBUG) && $(WITH_OPTIM)
    {
        C++FLAGS += -DNDEBUG -g ;
    }
    else if $(WITH_DEBUG)
    {
        C++FLAGS += -DDEBUG -g ;
    }
    else
    {
        C++FLAGS += -DNDEBUG ;
    }

    Configure C++FLAGS ;
}


rule CheckCc
{
    Gcc-CheckCc ;
}


rule CheckC++
{
    Gcc-CheckC++ ;
}


##############################################################################
# Build rules
##############################################################################

rule FDefines
{ return -D$(<) ; }


rule FIncludes
{ return -I$(<) ; }


